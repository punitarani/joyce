{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "src/**/*",
    "index.js",
    "__tests__/**/*"
  ],
  "typeRoots": [
    "src/types",
    "node_modules/@types"
  ],
  "exclude": [
    "node_modules",
    "android",
    "ios"
  ]
}